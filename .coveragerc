[run]
source = .
omit =
    venv/*
    tests/*
    __pycache__/*
    .tox/*
    .eggs/*
    *.egg-info/*
    setup.py
    dashboard/*
    data/*
    logs/*
    output/*
    # Exclude SQLAlchemy-dependent modules (Python 3.14 compatibility issues)
    database.py
    scheduler.py
    scheduler_api.py
    scheduler_jobs.py
    scraper_db_integration.py
    db/*
    models/*
    migrations/*
    app.py
    # Exclude test files
    test_*.py
    example.py
branch = True

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    class .*\bProtocol\):
    @(abc\.)?abstractmethod
    if TYPE_CHECKING:
    \.\.\.
show_missing = True
skip_covered = False
fail_under = 72

[html]
directory = htmlcov
